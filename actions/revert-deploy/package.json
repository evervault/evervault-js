{
  "name": "@ev/revert-s3-deploy",
  "description": "GitHub Actions for revert S3 deployments",
  "private": true,
  "exports": "./dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsup --config packages/tsconfig/app.tsup.config.json",
    "build:watch": "npm run build -- --watch",
    "clean": "rm -rf .turbo .nyc_output node_modules dist",
    "lint": "tsc && eslint .",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "@aws-sdk/client-s3": "^3.420.0"
  },
  "devDependencies": {
    "@types/node": "^20.4.1",
    "tsconfig": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.5.4"
  }
}
