{
  "name": "@evervault/react-native",
  "description": "Evervault SDK for React Native",
  "version": "2.7.0",
  "source": "./src/index.ts",
  "main": "./build/cjs/index.js",
  "module": "./build/esm/index.js",
  "types": "./build/esm/index.d.ts",
  "files": [
    "src",
    "build",
    "ios",
    "android",
    "native-evervault.podspec"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evervault/evervault-js.git"
  },
  "author": "Engineering <engineering@evervault.com> (https://evervault.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/evervault/evervault-js/issues"
  },
  "homepage": "https://docs.evervault.com/sdks/react-native",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "prebuild": "pnpm vendor:ios && pnpm codegen",
    "build": "rollup -c",
    "watch": "rollup -c --watch",
    "codegen": "rimraf build android/app && react-native codegen --source library",
    "vendor:ios": "node scripts/vendor-spm-dependencies.mjs",
    "prepack": "pnpm vendor:ios",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "peerDependencies": {
    "expo": ">=53.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.76.0",
    "react-native-webview": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    }
  },
  "dependencies": {
    "@evervault/card-validator": "workspace:*",
    "@hookform/resolvers": "^5.4.0",
    "react-hook-form": "^7.54.2",
    "react-native-mask-input": "^1.2.3",
    "test-renderer": "^1.2.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@srsholmes/vitest-react-native": "^0.1.5",
    "@testing-library/react-native": "^14.0.1",
    "@types/react": "catalog:",
    "expo": "catalog:",
    "glob": "^11.0.3",
    "react": "catalog:",
    "react-native": "catalog:",
    "react-native-webview": "catalog:",
    "rimraf": "^6.0.1",
    "rollup": "^4.59.0",
    "tsconfig": "workspace:*",
    "vitest": "catalog:"
  },
  "swiftDependencies": {
    "evervault-ios": [
      "Sources/EvervaultCore"
    ]
  },
  "codegenConfig": {
    "name": "NativeEvervaultSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.nativeevervault"
    }
  }
}
